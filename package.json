{
  "name": "solargalaxy",
  "version": "0.1.0",
  "private": true,
  "description": "SolarGalaxy — сайт компании, CRM, виртуальный склад",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:render": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client",
    "db:push": "npm run db:push --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "db:backup": "node scripts/backup-db.mjs",
    "whatsapp:setup": "npm run whatsapp:setup --workspace=server",
    "green:setup": "npm run green:setup --workspace=server",
    "green:verify": "npm run green:verify --workspace=server",
    "render:connect": "node scripts/render-connect-local.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
