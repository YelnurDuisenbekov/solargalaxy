generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
  CLIENT
}

enum DealStatus {
  NEW
  IN_PROGRESS
  WON
  LOST
}

enum StockMovementType {
  IN
  OUT
  ADJUST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole @default(CLIENT)
  isActive     Boolean  @default(true)
  company      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deals        Deal[]
  stockMoves   StockMovement[] @relation("MovementAuthor")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  source    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal      Deal?
}

model Deal {
  id          String     @id @default(cuid())
  title       String
  amount      Float      @default(0)
  status      DealStatus @default(NEW)
  notes       String?
  leadId      String?    @unique
  lead        Lead?      @relation(fields: [leadId], references: [id])
  clientId    String?
  client      User?      @relation(fields: [clientId], references: [id])
  assigneeId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  category    String?
  unit        String   @default("шт")
  price       Float    @default(0)
  description String?
  minStock    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock       StockItem?
  movements   StockMovement[]
}

model StockItem {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(0)
  location  String   @default("Основной склад")
  updatedAt DateTime @updatedAt
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  type        StockMovementType
  quantity    Int
  note        String?
  authorId    String?
  author      User?             @relation("MovementAuthor", fields: [authorId], references: [id])
  createdAt   DateTime          @default(now())
}

model OneCSyncLog {
  id        String   @id @default(cuid())
  direction String
  entity    String
  status    String
  payload   String?
  message   String?
  createdAt DateTime @default(now())
}
