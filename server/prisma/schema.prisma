generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DIRECTOR
  MANAGER
  WAREHOUSE
  SUPPLY
  ACCOUNTANT
  CONTRACTOR
  CLIENT
  EMPLOYEE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SURVEY
  CONVERTED
  LOST
}

enum DealStatus {
  NEW
  IN_PROGRESS
  WON
  LOST
}

enum ProjectPhase {
  SURVEY
  DESIGN
  BIDDING
  PROCUREMENT
  INSTALLATION
  COMMISSIONING
  COMPLETED
  CANCELLED
}

enum SystemType {
  ON_GRID
  OFF_GRID
  HYBRID
}

enum ObjectType {
  HOUSE
  OFFICE
  FARM
  INDUSTRIAL
  OTHER
}

enum KitCategory {
  PANEL
  INVERTER
  BATTERY
  MOUNTING
  COMMISSIONING
  CABLE
  OTHER
}

enum CostAllocation {
  PER_PANEL
  PER_KW
  PER_PROJECT
  PERCENT_EQUIPMENT
}

enum NotificationType {
  PURCHASE_REQUIRED
  LOW_STOCK
  PROJECT_UPDATE
  QUALIFIED_LEAD_REMINDER
  AUTO_WHATSAPP_FOLLOWUP
  MATERIALS_APPROVAL
  STOCK_ADJUSTMENT
  MATERIAL_TRANSFER
  ASSIGNEE_CHANGED
  MATERIAL_WRITE_OFF
}

enum MaterialTransferActStatus {
  PENDING_MANAGER
  ACCEPTED
}

enum MaterialWriteOffStatus {
  PENDING_DIRECTOR
  PENDING_ACCOUNTANT
  APPROVED
  REJECTED
}

enum StockAdjustmentStatus {
  PENDING_DIRECTOR
  APPROVED
  REJECTED
}

enum MaterialsApprovalStatus {
  NONE
  PENDING_DIRECTOR
  APPROVED
  RETURNED
}

enum BidStatus {
  PENDING
  WON
  LOST
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  TASK
  NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUST
}

model User {
  id           String   @id @default(cuid())
  login        String   @unique
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole @default(CLIENT)
  isActive     Boolean  @default(true)
  company      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  permissions      UserPermission[]
  deals            Deal[]          @relation("DealClient")
  assignedLeads    Lead[]          @relation("LeadAssignee")
  assignedDeals    Deal[]          @relation("DealAssignee")
  assignedProjects Project[]       @relation("ProjectAssignee")
  clientProjects   Project[]       @relation("ProjectClient")
  clientInvoices   Invoice[]       @relation("InvoiceClient")
  clientLeads      Lead[]          @relation("LeadClient")
  stockMoves       StockMovement[] @relation("MovementAuthor")
  stockReceipts    StockReceipt[]  @relation("StockReceiptAuthor")
  stockAdjustments StockAdjustmentBatch[] @relation("StockAdjustmentAuthor")
  activities       Activity[]      @relation("ActivityAuthor")
  notifications    Notification[]  @relation("NotificationUser")
  sentNotifications Notification[] @relation("NotificationFrom")
  contractorBids   ContractorBid[]
  uploadedAttachments ProjectAttachment[] @relation("ProjectAttachmentUploader")
  transferActsIssued   MaterialTransferAct[] @relation("TransferActIssuer")
  transferActsAccepted MaterialTransferAct[] @relation("TransferActAcceptor")
  writeOffRequests     MaterialWriteOffBatch[] @relation("WriteOffRequester")
  writeOffsDirector    MaterialWriteOffBatch[] @relation("WriteOffDirector")
  writeOffsAccountant  MaterialWriteOffBatch[] @relation("WriteOffAccountant")
}

model UserPermission {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    String

  @@unique([userId, key])
}

model Lead {
  id          String     @id @default(cuid())
  fullName    String
  phone       String
  email       String?
  city        String?
  objectType  ObjectType @default(OTHER)
  systemType  SystemType @default(ON_GRID)
  capacityKw  Float?
  source      String     @default("Сайт")
  notes       String?
  address     String?
  surveyAt    DateTime?
  status            LeadStatus @default(NEW)
  contactedAt       DateTime?
  qualifiedAt         DateTime?
  autoWhatsAppSentAt  DateTime?
  assigneeId          String?
  assignee    User?      @relation("LeadAssignee", fields: [assigneeId], references: [id])
  clientId    String?
  client      User?      @relation("LeadClient", fields: [clientId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  deal        Deal?
  project     Project?
  activities  Activity[]
  proposalAmount     Float   @default(0)
  proposalCustomized Boolean @default(false)
  proposalItems      LeadProposalItem[]
}

model LeadProposalItem {
  id          String      @id @default(cuid())
  leadId      String
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?    @relation(fields: [productId], references: [id])
  category    KitCategory
  name        String
  quantity    Float       @default(1)
  unitPrice   Float       @default(0)
  discountPct Float       @default(0)
  sortOrder   Int         @default(0)

  @@index([leadId])
}

model Deal {
  id           String     @id @default(cuid())
  title        String
  fullName     String?
  phone        String?
  city         String?
  objectType   ObjectType @default(OTHER)
  systemType   SystemType @default(ON_GRID)
  capacityKw   Float?
  amount       Float      @default(0)
  discountPct  Float      @default(0)
  status       DealStatus @default(NEW)
  notes        String?
  address      String?
  leadId       String?    @unique
  lead         Lead?      @relation(fields: [leadId], references: [id])
  clientId     String?
  client       User?      @relation("DealClient", fields: [clientId], references: [id])
  assigneeId   String?
  assignee     User?      @relation("DealAssignee", fields: [assigneeId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  kitItems     DealKitItem[]
  project      Project?
  activities   Activity[]
}

model DealKitItem {
  id              String      @id @default(cuid())
  dealId          String
  deal            Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?    @relation(fields: [productId], references: [id])
  category        KitCategory
  name            String
  quantity        Int         @default(1)
  unitPrice       Float       @default(0)
  discountPct     Float       @default(0)
  stockAvailable  Int         @default(0)

  @@index([dealId])
}

model Project {
  id              String       @id @default(cuid())
  projectNumber   String?      @unique
  title           String
  phase           ProjectPhase @default(DESIGN)
  capacityKw      Float?
  city            String?
  address         String?
  notes           String?
  clientPhone     String?
  auctionBrief    String?
  auctionOpen     Boolean      @default(false)
  auctionLaunched Boolean      @default(false)
  auctionDeadline DateTime?
  startDate       DateTime?
  endDate         DateTime?
  dealId          String?      @unique
  deal            Deal?        @relation(fields: [dealId], references: [id])
  leadId          String?      @unique
  lead            Lead?        @relation(fields: [leadId], references: [id])
  clientId        String?
  client          User?        @relation("ProjectClient", fields: [clientId], references: [id])
  assigneeId      String?
  assignee        User?        @relation("ProjectAssignee", fields: [assigneeId], references: [id])
  winningBidId    String?      @unique
  winningBid      ContractorBid? @relation("WinningBid", fields: [winningBidId], references: [id])
  materialsApprovalStatus MaterialsApprovalStatus @default(NONE)
  materialsApprovalNote   String?
  materialsApprovedAt     DateTime?
  kitGlobalDiscountPct    Float   @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  materials       ProjectMaterial[]
  invoices        Invoice[]
  activities      Activity[]
  stockMoves      StockMovement[]
  stockReservations StockReservation[]
  transferActs      MaterialTransferAct[]
  writeOffBatches   MaterialWriteOffBatch[]
  bids            ContractorBid[] @relation("ProjectBids")
  attachments     ProjectAttachment[]

  @@index([clientPhone])
}

model ProjectAttachment {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  mimeType     String?
  size         Int      @default(0)
  storagePath  String
  uploadedById String?
  uploadedBy   User?    @relation("ProjectAttachmentUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model ContractorBid {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation("ProjectBids", fields: [projectId], references: [id], onDelete: Cascade)
  contractorId String
  contractor   User      @relation(fields: [contractorId], references: [id])
  price        Float
  note         String?
  status       BidStatus @default(PENDING)
  createdAt    DateTime  @default(now())
  wonProject   Project?  @relation("WinningBid")

  @@unique([projectId, contractorId])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation("NotificationUser", fields: [userId], references: [id])
  fromUserId String?
  fromUser   User?            @relation("NotificationFrom", fields: [fromUserId], references: [id])
  type       NotificationType
  title      String
  message    String
  read       Boolean          @default(false)
  projectId  String?
  productId  String?
  createdAt  DateTime         @default(now())
}

model ProjectMaterial {
  id              String  @id @default(cuid())
  projectId       String
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  quantityPlanned    Int     @default(0)
  quantityIssued     Int     @default(0)
  quantityAccepted   Int     @default(0)
  quantityWrittenOff Int     @default(0)
  unitPrice          Float?
  purchasePrice   Float?
  discountPct     Float   @default(0)
  writeOffItems      MaterialWriteOffBatchItem[]

  @@unique([projectId, productId])
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType @default(TASK)
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean      @default(false)
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId    String?
  author      User?        @relation("ActivityAuthor", fields: [authorId], references: [id])
  createdAt   DateTime     @default(now())
}

model Invoice {
  id        String        @id @default(cuid())
  number    String        @unique
  amount    Float         @default(0)
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime?
  paidAt    DateTime?
  notes     String?
  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id])
  clientId  String?
  client    User?         @relation("InvoiceClient", fields: [clientId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  category    String?
  unit        String   @default("шт")
  price         Float    @default(0)
  purchasePrice Float    @default(0)
  description String?
  minStock    Int      @default(0)
  kitCategory KitCategory?
  powerW      Float?
  capacityKw  Float?
  capacityKwh Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock              StockItem?
  movements          StockMovement[]
  receiptItems       StockReceiptItem[]
  stockAdjustmentItems StockAdjustmentItem[]
  projectMats        ProjectMaterial[]
  stockReservations  StockReservation[]
  transferActItems   MaterialTransferActItem[]
  writeOffBatchItems MaterialWriteOffBatchItem[]
  kitItems           DealKitItem[]
  proposalCostLines  ProposalCostLine[]
  leadProposalItems  LeadProposalItem[]
}

model ProposalCostLine {
  id                String         @id @default(cuid())
  systemType        SystemType
  category          KitCategory
  allocation        CostAllocation @default(PER_PROJECT)
  productId         String?
  product           Product?       @relation(fields: [productId], references: [id])
  qtyMultiplier     Float          @default(1)
  unitPriceOverride Float?
  label             String?
  sortOrder         Int            @default(0)
  enabled           Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([systemType])
}

model StockItem {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(0)
  location  String   @default("Основной склад")
  updatedAt DateTime @updatedAt
}

model StockReservation {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, productId])
  @@index([productId])
}

model MaterialTransferAct {
  id           String                    @id @default(cuid())
  actNumber    String                    @unique
  projectId    String
  project      Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       MaterialTransferActStatus @default(PENDING_MANAGER)
  issuedById   String
  issuedBy     User                      @relation("TransferActIssuer", fields: [issuedById], references: [id])
  acceptedById String?
  acceptedBy   User?                     @relation("TransferActAcceptor", fields: [acceptedById], references: [id])
  note         String?
  issuedAt     DateTime                  @default(now())
  acceptedAt   DateTime?
  items        MaterialTransferActItem[]

  @@index([projectId])
  @@index([status])
}

model MaterialTransferActItem {
  id        String              @id @default(cuid())
  actId     String
  act       MaterialTransferAct @relation(fields: [actId], references: [id], onDelete: Cascade)
  productId String
  product   Product             @relation(fields: [productId], references: [id])
  quantity  Int

  @@index([actId])
}

model MaterialWriteOffBatch {
  id                     String                 @id @default(cuid())
  projectId              String
  project                Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedById          String
  requestedBy            User                   @relation("WriteOffRequester", fields: [requestedById], references: [id])
  status                 MaterialWriteOffStatus @default(PENDING_DIRECTOR)
  note                   String?
  directorApprovedAt     DateTime?
  directorApprovedById   String?
  directorApprovedBy     User?                  @relation("WriteOffDirector", fields: [directorApprovedById], references: [id])
  accountantApprovedAt DateTime?
  accountantApprovedById String?
  accountantApprovedBy   User?                  @relation("WriteOffAccountant", fields: [accountantApprovedById], references: [id])
  rejectNote             String?
  rejectedAt             DateTime?
  createdAt              DateTime               @default(now())
  items                  MaterialWriteOffBatchItem[]

  @@index([projectId])
  @@index([status])
}

model MaterialWriteOffBatchItem {
  id                String              @id @default(cuid())
  batchId           String
  batch             MaterialWriteOffBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  projectMaterialId String
  projectMaterial   ProjectMaterial     @relation(fields: [projectMaterialId], references: [id])
  productId         String
  product           Product             @relation(fields: [productId], references: [id])
  quantity          Int

  @@index([batchId])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  type        StockMovementType
  quantity    Int
  note        String?
  projectId   String?
  project     Project?          @relation(fields: [projectId], references: [id])
  receiptId   String?
  receipt     StockReceipt?     @relation(fields: [receiptId], references: [id])
  authorId    String?
  author      User?             @relation("MovementAuthor", fields: [authorId], references: [id])
  createdAt   DateTime          @default(now())
}

model StockReceipt {
  id               String   @id @default(cuid())
  receivedAt       DateTime @default(now())
  invoiceDate      DateTime
  invoiceNumber    String
  seller           String?
  supplierId       String?
  supplier         Supplier? @relation(fields: [supplierId], references: [id])
  priceIncludesVat Boolean  @default(true)
  authorId         String?
  author           User?    @relation("StockReceiptAuthor", fields: [authorId], references: [id])
  createdAt        DateTime @default(now())
  items            StockReceiptItem[]
  movements        StockMovement[]

  @@index([invoiceNumber])
  @@index([receivedAt])
  @@index([supplierId])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  bin       String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  receipts  StockReceipt[]

  @@index([name])
}

model StockReceiptItem {
  id        String       @id @default(cuid())
  receiptId String
  receipt   StockReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float        @default(0)

  @@index([receiptId])
}

model StockAdjustmentBatch {
  id         String                @id @default(cuid())
  status     StockAdjustmentStatus @default(PENDING_DIRECTOR)
  note       String?
  authorId   String?
  author     User?                 @relation("StockAdjustmentAuthor", fields: [authorId], references: [id])
  approvedAt DateTime?
  createdAt  DateTime              @default(now())
  items      StockAdjustmentItem[]

  @@index([status])
  @@index([createdAt])
}

model StockAdjustmentItem {
  id             String             @id @default(cuid())
  batchId        String
  batch          StockAdjustmentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  productId      String
  product        Product              @relation(fields: [productId], references: [id])
  quantityBefore Int
  quantityAfter  Int

  @@index([batchId])
}

model OneCSyncLog {
  id        String   @id @default(cuid())
  direction String
  entity    String
  status    String
  payload   String?
  message   String?
  createdAt DateTime @default(now())
}
