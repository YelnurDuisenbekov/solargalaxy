DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production-solargalaxy"
PORT=4000
CLIENT_URL="http://localhost:5173"

# ── WhatsApp Cloud API (Meta Business) ──
# 1. developers.facebook.com → приложение → WhatsApp → API Setup
# 2. Скопируйте временный или постоянный токен и Phone number ID
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# Версия Graph API (по умолчанию v21.0)
WHATSAPP_API_VERSION="v21.0"

# Webhook (для входящих сообщений и статусов доставки)
# Verify token — любая строка, та же что укажете в Meta Developer Console
WHATSAPP_VERIFY_TOKEN="solargalaxy-webhook-secret"
# Публичный URL webhook для отображения в админке (ngrok / production)
WHATSAPP_WEBHOOK_PUBLIC_URL="https://your-domain.com/api/whatsapp/webhook"

# Шаблоны сообщений (обязательны для follow-up через 24+ ч после «Заинтересован»)
# Создайте и одобрите в Meta Business Manager → WhatsApp → Message templates
#
# Пример sg_followup (ru), 2 переменных в теле:
#   Здравствуйте, {{1}}! Это {{2}} из SOLAR GALAXY. Вы интересовались солнечной станцией...
WHATSAPP_TEMPLATE_FOLLOWUP="sg_followup"
#
# Пример sg_initial (ru), 4 переменных: имя, менеджер, город, мощность
WHATSAPP_TEMPLATE_INITIAL="sg_initial"
WHATSAPP_TEMPLATE_LANGUAGE="ru"

# Напоминания менеджерам
REMINDER_TIMEZONE="Asia/Almaty"
REMINDER_HOUR=10
REMINDER_MINUTE=0

# 1С (будущая интеграция)
# ONEC_API_URL=""
# ONEC_API_KEY=""
